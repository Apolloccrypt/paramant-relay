# PARAMANT secrets — copy to .env and fill in
# .env is NEVER committed to git

# ── Relay (required) ──────────────────────────────────────────────────────────
ADMIN_TOKEN=pgp_xxxx
TOTP_SECRET=BASE32_SECRET_HERE
RESEND_API_KEY=re_xxxx
FLY_API_TOKEN=FlyV1_xxxx

# ── Integrations stack (n8n + Prometheus + Grafana) ───────────────────────────
# Run: bash deploy/setup-integrations.sh   (after filling these in)

N8N_USER=admin
N8N_PASSWORD=change_me_strong_password

GRAFANA_USER=admin
GRAFANA_PASSWORD=change_me_strong_password

# Optional: Claude API key for AI document analysis workflows in n8n
ANTHROPIC_API_KEY=sk-ant-xxxx
