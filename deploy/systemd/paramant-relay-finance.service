[Unit]
Description=PARAMANT Relay - finance
After=network.target

[Service]
Environment=TOTP_SECRET=REPLACE_TOTP_SECRET
Environment=RESEND_API_KEY=REPLACE_RESEND_KEY
Type=simple
User=paramant
WorkingDirectory=/home/paramant/relay-finance
ExecStart=/usr/bin/node relay.js
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
