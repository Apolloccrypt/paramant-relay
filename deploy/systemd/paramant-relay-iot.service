[Unit]
Description=PARAMANT Relay - iot
After=network.target

[Service]
Environment=PORT=3004
Environment=SECTOR=iot
Environment=ADMIN_TOKEN=REPLACE_ADMIN_TOKEN
Environment=USERS_FILE=/home/paramant/relay-iot/users.json
Environment=TOTP_SECRET=REPLACE_TOTP_SECRET
Environment=RESEND_API_KEY=REPLACE_RESEND_KEY
Environment=LOG_LEVEL=info
Type=simple
User=paramant
WorkingDirectory=/home/paramant/relay-iot
ExecStart=/usr/bin/node relay.js
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
