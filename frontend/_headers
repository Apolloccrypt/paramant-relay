/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  Permissions-Policy: camera=(self), microphone=(), geolocation=(), payment=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

/index.html
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src https://health.paramant.app https://legal.paramant.app https://finance.paramant.app https://iot.paramant.app wss://*.onion; img-src 'self' data: blob:; font-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'none'
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache

/relay-feed.html
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src https://health.paramant.app https://legal.paramant.app https://finance.paramant.app https://iot.paramant.app; frame-ancestors 'none'
  Cache-Control: no-store

/privacy.html
  Cache-Control: no-store

/download.html
  Cache-Control: no-store
