# PARAMANT relay — environment variables
# Copy to .env and fill in your values before running docker compose.
# Never commit .env to git.

# ── Required ─────────────────────────────────────────────────────────────────

# Random secret used to authenticate /v2/reload-users and admin endpoints.
# Generate: openssl rand -hex 32
ADMIN_TOKEN=

# ── License ───────────────────────────────────────────────────────────────────
#
# Community Edition (default, free forever): max 5 active API keys.
# Licensed Edition: unlimited API keys, issued per-operator.
#
# Key format: plk_<base64url(payload_json + ed25519_signature)>
#   payload: { max_keys, expires_at, issued_to, issued_at }
#   signature: Ed25519, verified against hardcoded public key in relay.js
#
# Keys are cryptographically signed — they cannot be forged or modified.
# An invalid or expired key falls back to Community Edition gracefully.
#
# Get a license: https://paramant.app/pricing
# Verify a key:  node scripts/verify-license.js <your-plk-key>
PLK_KEY=

# ── Relay behaviour ───────────────────────────────────────────────────────────

# Relay mode controls which endpoints are enabled.
# Options: ghost_pipe | iot
# Default: ghost_pipe  (end-to-end encrypted messaging, ML-KEM-768)
RELAY_MODE=ghost_pipe

# Memory limits per relay process (MB).
RAM_RESERVE_MB=256
RAM_LIMIT_MB=1024

# ── Users / API keys ─────────────────────────────────────────────────────────

# Path to users.json inside the container (mapped to a named volume).
# You can pre-populate this file or use the admin CLI to add keys.
# USERS_FILE=/data/users.json   ← set automatically by docker-compose.yml

# Alternatively, provide the full users.json inline as a JSON string.
# Useful for secret managers (Vault, AWS Secrets Manager, Fly secrets).
# If set, USERS_FILE is ignored.
# USERS_JSON={"api_keys":[{"key":"pgp_xxx","plan":"pro","label":"alice","active":true}]}

# ── Email (optional — needed for welcome mails and MFA) ───────────────────

# Resend (https://resend.com) — recommended
RESEND_API_KEY=

# ── TOTP / MFA (optional) ─────────────────────────────────────────────────

# Base32 secret for admin TOTP (Google Authenticator compatible).
# Generate: python3 -c "import secrets,base64; print(base64.b32encode(secrets.token_bytes(20)).decode())"
TOTP_SECRET=

# ── Billing / Stripe (optional — only needed for SaaS deployments) ────────

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_KANTOOR=
STRIPE_DEVICE_PRICE_ID=

# ── Logging (optional) ───────────────────────────────────────────────────────
# Log verbosity: debug | info | warn | error  (default: info)
# LOG_LEVEL=info

# ── Port overrides (optional) ─────────────────────────────────────────────────
# Change if ports 80/443 are already in use (e.g. Caddy, Apache, nginx)
# HTTP_PORT=8080
# HTTPS_PORT=8443

# ── CT log persistence (optional) ────────────────────────────────────────────
# Set CT_FILE to persist the Certificate Transparency log to disk.
# When unset, the CT log is RAM-only (default, recommended for most deployments).
# Use an absolute path; the directory must be writable by the relay process.
# CT_FILE=/data/ct-log.ndjson

# ── NATS JetStream (optional — push transport) ────────────────────────────────
# When unset, NATS is disabled entirely. Set NATS_URL to enable.
# Use tls:// for non-localhost connections to prevent metadata exposure.
# NATS_URL=tls://your-nats-server:4222
# NATS_USER=paramant
# NATS_PASS=
# NATS_TOKEN=
