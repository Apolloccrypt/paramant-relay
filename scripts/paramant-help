#!/usr/bin/env bash
# paramant-help — command reference

GREEN='\033[0;32m'; BOLD='\033[1m'; DIM='\033[2m'; RESET='\033[0m'

echo ""
echo -e "${BOLD}  PARAMANT — CLI Reference${RESET}"
echo -e "  Post-quantum encrypted file relay"
echo -e "  ${DIM}paramant.app · github.com/Apolloccrypt/paramant-relay${RESET}"
echo ""

section() { echo -e "\n  ${GREEN}${1}${RESET}"; }
cmd()     { printf "  %-28s %s\n" "$1" "$2"; }

section "Setup & diagnostics"
cmd "paramant-setup"        "First-time wizard — key + relay URL"
cmd "paramant-status"       "Relay health across all sectors"
cmd "paramant-doctor"       "Automated health check with fix hints"
cmd "paramant-info"         "System info, uptime, relay version"
cmd "paramant-relay-setup"  "Clone + configure + start relay"

section "File transfer"
cmd "paramant-sender.py"    "Send a file to a relay sector"
cmd "paramant-receiver.py"  "Receive and forward from a relay sector"

section "Sector tools"
cmd "paramant-referral"     "Healthcare referral (NEN 7510, HL7 FHIR, DICOM)"
cmd "paramant-notary"       "Legal document transport (eIDAS, KNB)"
cmd "paramant-legal"        "Court document relay"
cmd "paramant-payslip"      "HR payslip distribution (GDPR)"
cmd "paramant-firmware"     "IoT/body cam firmware updates (IEC 62443)"
cmd "paramant-cra"          "Software supply chain relay (EU CRA 2027)"
cmd "paramant-ticket"       "One-time transit ticket issuer/verifier"

section "CT log & verification"
cmd "paramant-verify-sth"   "Verify ML-DSA-65 signed tree head"
cmd "paramant-receipt"      "View or verify a delivery receipt"
cmd "paramant-verify-peers" "Cross-check STH consistency across relays"

section "Key management"
cmd "paramant-keys"         "List all API keys"
cmd "paramant-key-add"      "Add new API key"
cmd "paramant-key-revoke"   "Revoke an API key"

section "Security & network"
cmd "security-status"       "All security layers at a glance"
cmd "paramant-ports"        "Firewall rules + listening ports"
cmd "paramant-scan"         "LAN relay discovery + registry"
cmd "paramant-verify"       "TOFU fingerprint verification"
cmd "paramant-security"     "Firewall + SSH status"
cmd "paramant-ip"           "Show IP addresses"

section "Data & maintenance"
cmd "paramant-backup"       "Backup keys + CT log"
cmd "paramant-restore"      "Restore from backup"
cmd "paramant-export"       "Export audit log to USB"
cmd "paramant-logs"         "Live log stream"
cmd "paramant-update"       "Check for updates"

section "System"
cmd "paramant-boot-choice"  "Interactive boot menu"
cmd "paramant-migrate"      "Migration assistant"
cmd "paramant-roadmap"      "PQC migration roadmap generator"
cmd "paramant-crypto-audit" "Scan infrastructure for quantum-vulnerable crypto"

echo ""
echo -e "  ${DIM}Install all tools: curl -fsSL https://paramant.app/install-client.sh | bash${RESET}"
echo -e "  ${DIM}Docs: paramant.app/docs${RESET}"
echo ""
